<?xml version="1.0" encoding="utf-8"?>

<!-- Layoutet for detaljeskærmen, hvor en valgt begivenhed vises -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Viser navnet på begivenheden -->
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="26sp"
        android:textStyle="bold" />

    <!-- Viser datoen for begivenheden -->
    <TextView
        android:id="@+id/dateTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

    <!-- Viser den fulde beskrivelse af begivenheden -->
    <TextView
        android:id="@+id/descriptionTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp" />

    <!-- Knap der åbner begivenhedens link i en browser -->
    <Button
        android:id="@+id/browserButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Åbn i browser"
        android:layout_marginTop="24dp" />

    <!-- Knap der sender brugeren tilbage til startskærmen -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tilbage"
        android:layout_marginTop="24dp" />

</LinearLayout>